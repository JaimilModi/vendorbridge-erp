datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  PROCUREMENT_OFFICER
  VENDOR
  MANAGER
}

enum VendorStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum RFQStatus {
  DRAFT
  OPEN
  CLOSED
  AWARDED
}

enum QuotationStatus {
  DRAFT
  SUBMITTED
  ACCEPTED
  REJECTED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PurchaseOrderStatus {
  DRAFT
  ISSUED
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
}

model User {
  id           String        @id @default(uuid()) @db.Uuid
  email        String        @unique
  passwordHash String
  firstName    String
  lastName     String
  role         Role
  vendorId     String?       @db.Uuid
  vendor       Vendor?       @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  approvals    Approval[]
  activityLogs ActivityLog[]
  notifications Notification[]
  rfqsCreated  RFQ[]         @relation("RFQS_CREATED")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([email])
  @@index([role])
}

model Vendor {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  email          String          @unique
  phone          String?
  address        String?
  gstNumber      String?
  status         VendorStatus    @default(ACTIVE)
  users          User[]
  quotations     Quotation[]
  purchaseOrders PurchaseOrder[]
  invoices       Invoice[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([email])
  @@index([status])
}

model RFQ {
  id          String      @id @default(uuid()) @db.Uuid
  title       String
  description String?
  status      RFQStatus   @default(DRAFT)
  deadline    DateTime
  createdById String      @db.Uuid
  createdBy   User        @relation("RFQS_CREATED", fields: [createdById], references: [id])
  items       RFQItem[]
  quotations  Quotation[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([status])
  @@index([createdById])
}

model RFQItem {
  id             String          @id @default(uuid()) @db.Uuid
  rfqId          String          @db.Uuid
  rfq            RFQ             @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  productName    String
  description    String?
  quantity       Int
  uom            String
  quotationItems QuotationItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([rfqId])
}

model Quotation {
  id            String          @id @default(uuid()) @db.Uuid
  rfqId         String          @db.Uuid
  rfq           RFQ             @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  vendorId      String          @db.Uuid
  vendor        Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  status        QuotationStatus @default(DRAFT)
  totalAmount   Decimal         @db.Decimal(12, 2)
  validityDate  DateTime
  items         QuotationItem[]
  approvals     Approval[]
  purchaseOrders PurchaseOrder[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([rfqId])
  @@index([vendorId])
  @@index([status])
}

model QuotationItem {
  id               String    @id @default(uuid()) @db.Uuid
  quotationId      String    @db.Uuid
  quotation        Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  rfqItemId        String    @db.Uuid
  rfqItem          RFQItem   @relation(fields: [rfqItemId], references: [id], onDelete: Cascade)
  unitPrice        Decimal   @db.Decimal(12, 2)
  totalPrice       Decimal   @db.Decimal(12, 2)
  deliveryTimeline String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([quotationId])
  @@index([rfqItemId])
}

model Approval {
  id            String         @id @default(uuid()) @db.Uuid
  quotationId   String         @db.Uuid
  quotation     Quotation      @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  approvedById  String         @db.Uuid
  approvedBy    User           @relation(fields: [approvedById], references: [id])
  status        ApprovalStatus @default(PENDING)
  remarks       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([quotationId])
  @@index([approvedById])
  @@index([status])
}

model PurchaseOrder {
  id          String              @id @default(uuid()) @db.Uuid
  poNumber    String              @unique
  quotationId String              @db.Uuid
  quotation   Quotation           @relation(fields: [quotationId], references: [id])
  vendorId    String              @db.Uuid
  vendor      Vendor              @relation(fields: [vendorId], references: [id])
  status      PurchaseOrderStatus @default(DRAFT)
  totalAmount Decimal             @db.Decimal(12, 2)
  items       PurchaseOrderItem[]
  invoices    Invoice[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([poNumber])
  @@index([quotationId])
  @@index([vendorId])
  @@index([status])
}

model PurchaseOrderItem {
  id          String        @id @default(uuid()) @db.Uuid
  poId        String        @db.Uuid
  po          PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  productName String
  description String?
  quantity    Int
  unitPrice   Decimal       @db.Decimal(12, 2)
  totalPrice  Decimal       @db.Decimal(12, 2)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([poId])
}

model Invoice {
  id            String        @id @default(uuid()) @db.Uuid
  invoiceNumber String        @unique
  poId          String        @db.Uuid
  po            PurchaseOrder @relation(fields: [poId], references: [id])
  vendorId      String        @db.Uuid
  vendor        Vendor        @relation(fields: [vendorId], references: [id])
  status        InvoiceStatus @default(DRAFT)
  totalAmount   Decimal       @db.Decimal(12, 2)
  dueDate       DateTime
  items         InvoiceItem[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([invoiceNumber])
  @@index([poId])
  @@index([vendorId])
  @@index([status])
}

model InvoiceItem {
  id          String   @id @default(uuid()) @db.Uuid
  invoiceId   String   @db.Uuid
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productName String
  description String?
  quantity    Int
  unitPrice   Decimal  @db.Decimal(12, 2)
  totalPrice  Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([invoiceId])
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([read])
}

model ActivityLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
